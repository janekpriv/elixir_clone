{%- comment -%}
  sections/store-features.liquid
  Horizontal row or grid of store features (icon + title + optional description).
  Separator is desktop-only and skipped on the last block.
{%- endcomment -%}

{%- liquid
  assign block_count = section.blocks | where: 'type', 'feature' | size
  assign align_class = 'store-features__grid--center'
  if section.settings.alignment == 'left'
    assign align_class = 'store-features__grid--left'
  endif
-%}

{%- style -%}
  .store-features-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top:      {{ section.settings.padding_top }}px;
    padding-bottom:   {{ section.settings.padding_bottom }}px;
  }

  /* Icon size & color */
  .store-features-{{ section.id }} .store-features__icon-img,
  .store-features-{{ section.id }} .store-features__icon-svg {
    width:  {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    color:  {{ section.settings.icon_color }};
    fill:   {{ section.settings.icon_color }};
  }

  {%- if section.settings.show_icon_background -%}
    .store-features-{{ section.id }} .store-features__icon-wrap {
      background-color: var(--color-accent-glow);
      border-radius:    var(--radius-pill);
      padding:          12px;
    }
  {%- endif -%}

  /* Desktop grid: one row, equal columns based on block count */
  @media screen and (min-width: 750px) {
    .store-features-{{ section.id }} .store-features__grid {
      grid-template-columns: repeat({{ block_count }}, 1fr);
    }

    {%- if section.settings.show_separator and section.settings.layout == 'row' -%}
      .store-features-{{ section.id }} .store-features__item:not(:last-child) {
        border-right: 1px solid var(--color-elixir-border);
      }
    {%- endif -%}
  }

  .store-features-{{ section.id }} .store-features__heading {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
  }

  .store-features-{{ section.id }} .store-features__title {
    font-size: {{ section.settings.item_title_size }}px;
    font-weight: {{ section.settings.item_title_weight }};
  }

  .store-features-{{ section.id }} .store-features__desc {
    font-size: {{ section.settings.body_size }}px;
    font-weight: {{ section.settings.body_weight }};
  }
{%- endstyle -%}

<div
  class="store-features store-features-{{ section.id }}"
  aria-label="{{ section.settings.heading | default: 'Store features' | escape }}"
>
  <div class="page-width">

    {%- if section.settings.heading != blank -%}
      <h2 class="store-features__heading elixir-section-heading animate-on-scroll">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    <ul class="store-features__grid {{ align_class }} store-features__grid--{{ section.settings.layout }} list-unstyled animate-on-scroll">

      {%- for block in section.blocks -%}
        {%- if block.type == 'feature' -%}
          <li class="store-features__item" {{ block.shopify_attributes }}>

            {%- comment -%}── Icon ──────────────────────────────────────────{%- endcomment -%}
            <div class="store-features__icon-wrap">
              {%- if block.settings.icon != blank -%}
                {%- assign feat_alt = block.settings.title | escape -%}
                {{
                  block.settings.icon
                  | image_url: width: 128
                  | image_tag:
                    class: 'store-features__icon-img',
                    loading: 'lazy',
                    width: section.settings.icon_size,
                    height: section.settings.icon_size,
                    alt: feat_alt
                }}
              {%- else -%}
                {%- comment -%} Default SVG placeholder — checkmark shield {%- endcomment -%}
                <svg
                  class="store-features__icon-svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                  aria-hidden="true"
                >
                  <path
                    d="M12 2L4 5v6c0 5.25 3.5 10.15 8 11.35C16.5 21.15 20 16.25 20 11V5L12 2Z"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linejoin="round"
                  />
                  <path
                    d="M9 12l2 2 4-4"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              {%- endif -%}
            </div>

            {%- comment -%}── Text ──────────────────────────────────────────{%- endcomment -%}
            <div class="store-features__text">
              {%- if block.settings.title != blank -%}
                <p class="store-features__title">{{ block.settings.title }}</p>
              {%- endif -%}
              {%- if section.settings.show_description and block.settings.description != blank -%}
                <p class="store-features__desc">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>

          </li>
        {%- endif -%}
      {%- endfor -%}

    </ul>
  </div>
</div>

{% schema %}
{
  "name": "Store features",
  "tag": "section",
  "class": "section-store-features",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Leave empty to hide heading"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "row",  "label": "Horizontal row" },
        { "value": "grid", "label": "Grid" }
      ],
      "default": "row"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "left",   "label": "Left" }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "show_separator",
      "label": "Show separator between items",
      "info": "Visible on desktop in Horizontal row layout only",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description text",
      "default": true
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 24,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon colour",
      "default": "#00e5ff"
    },
    {
      "type": "checkbox",
      "id": "show_icon_background",
      "label": "Show icon circle background",
      "default": false
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#0a0a0a"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Section heading size",
      "min": 24,
      "max": 56,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Section heading weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra-bold" }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "item_title_size",
      "label": "Item title size",
      "min": 13,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "select",
      "id": "item_title_weight",
      "label": "Item title weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" }
      ],
      "default": "500"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Description size",
      "min": 12,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "select",
      "id": "body_weight",
      "label": "Description weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" }
      ],
      "default": "400"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image",
          "info": "Leave empty to use default shield icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Fast Shipping"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Delivered in 3-5 business days"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Store features",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "Fast Shipping",
            "description": "Delivered in 3-5 business days"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "30-Day Guarantee",
            "description": "No questions asked refund policy"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Secure Checkout",
            "description": "256-bit SSL encryption"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "24/7 Support",
            "description": "Our team is always here to help"
          }
        }
      ]
    }
  ]
}
{% endschema %}

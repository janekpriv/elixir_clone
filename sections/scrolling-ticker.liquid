{%- comment -%}
  sections/scrolling-ticker.liquid
  CSS-only infinite scrolling ticker. Content is duplicated by Liquid
  (two identical sets) so translateX(-50%) creates a seamless loop.
{%- endcomment -%}

{%- liquid
  assign anim_direction = 'normal'
  if section.settings.direction == 'ltr'
    assign anim_direction = 'reverse'
  endif
-%}

{%- style -%}
  .ticker-{{ section.id }} {
    --ticker-speed:          {{ section.settings.speed }}s;
    --ticker-bg:             {{ section.settings.background_color }};
    --ticker-color:          {{ section.settings.text_color }};
    --ticker-accent:         {{ section.settings.accent_color }};
    --ticker-font-size:      {{ section.settings.font_size }}px;
    --ticker-font-weight:    {{ section.settings.font_weight }};
    --ticker-letter-spacing: {{ section.settings.letter_spacing }};
    --ticker-direction:      {{ anim_direction }};
    background-color: {{ section.settings.background_color }};
    padding-top:      {{ section.settings.padding_top }}px;
    padding-bottom:   {{ section.settings.padding_bottom }}px;
  }

  {%- if section.settings.uppercase -%}
    .ticker-{{ section.id }} .ticker-item__text {
      text-transform: uppercase;
    }
  {%- endif -%}

  {%- if section.settings.pause_on_hover -%}
    .ticker-{{ section.id }}:hover .ticker-track {
      animation-play-state: paused;
    }
  {%- endif -%}
{%- endstyle -%}

<div
  class="ticker-wrapper ticker-{{ section.id }}"
  {%- if section.settings.heading != blank -%}
    aria-label="{{ section.settings.heading | escape }}"
  {%- endif -%}
>
  {%- if section.settings.heading != blank -%}
    <h2 class="visually-hidden">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}

  <div class="ticker-track">

    {%- comment -%}── Set 1 (visible, announces to screen readers) ──{%- endcomment -%}
    <div class="ticker-set">
      {%- for block in section.blocks -%}
        {%- if block.type == 'ticker_item' -%}
          <span class="ticker-item" {{ block.shopify_attributes }}>
            {%- if block.settings.icon != blank -%}
              {%- assign ticker_alt = block.settings.text | escape -%}
              {{
                block.settings.icon
                | image_url: width: 32
                | image_tag:
                  class: 'ticker-item__icon',
                  loading: 'lazy',
                  width: 16,
                  height: 16,
                  alt: ticker_alt
              }}
            {%- endif -%}
            <span class="ticker-item__text">{{ block.settings.text }}</span>
          </span>
          <span class="ticker-sep" aria-hidden="true">{{ section.settings.separator }}</span>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- comment -%}── Set 2 (duplicate, hidden from screen readers) ──{%- endcomment -%}
    <div class="ticker-set" aria-hidden="true">
      {%- for block in section.blocks -%}
        {%- if block.type == 'ticker_item' -%}
          <span class="ticker-item">
            {%- if block.settings.icon != blank -%}
              {%- assign ticker_alt = block.settings.text | escape -%}
              {{
                block.settings.icon
                | image_url: width: 32
                | image_tag:
                  class: 'ticker-item__icon',
                  loading: 'lazy',
                  width: 16,
                  height: 16,
                  alt: ticker_alt
              }}
            {%- endif -%}
            <span class="ticker-item__text">{{ block.settings.text }}</span>
          </span>
          <span class="ticker-sep" aria-hidden="true">{{ section.settings.separator }}</span>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Scrolling ticker",
  "tag": "section",
  "class": "section-ticker",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Accessible heading (hidden visually)",
      "default": "Store announcements"
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "s",
      "default": 30
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Scroll direction",
      "options": [
        { "value": "rtl", "label": "Right to left (default)" },
        { "value": "ltr", "label": "Left to right" }
      ],
      "default": "rtl"
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semibold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ],
      "default": "600"
    },
    {
      "type": "select",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "options": [
        { "value": "0em",   "label": "Normal" },
        { "value": "0.05em", "label": "Wide" },
        { "value": "0.1em",  "label": "Wider" }
      ],
      "default": "0.05em"
    },
    {
      "type": "checkbox",
      "id": "uppercase",
      "label": "Uppercase text",
      "default": true
    },
    {
      "type": "text",
      "id": "separator",
      "label": "Separator symbol",
      "default": "•"
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Separator / accent",
      "default": "#00e5ff"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 12
    }
  ],
  "blocks": [
    {
      "type": "ticker_item",
      "name": "Ticker item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "FREE SHIPPING OVER $50"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon (optional)",
          "info": "Displayed before text. Recommended size: 16×16px."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scrolling ticker",
      "blocks": [
        { "type": "ticker_item", "settings": { "text": "FREE SHIPPING OVER $50" } },
        { "type": "ticker_item", "settings": { "text": "30-DAY MONEY BACK GUARANTEE" } },
        { "type": "ticker_item", "settings": { "text": "TRUSTED BY 20,000+ CUSTOMERS" } },
        { "type": "ticker_item", "settings": { "text": "SECURE CHECKOUT" } }
      ]
    }
  ]
}
{% endschema %}

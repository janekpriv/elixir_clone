{%- comment -%}
  sections/statistics.liquid
  Big-number stats grid with optional count-up animation.
  Count-up is driven by assets/statistics-counter.js via IntersectionObserver.
{%- endcomment -%}

{%- liquid
  assign stat_blocks = section.blocks | where: 'type', 'stat'
  assign col_class   = 'statistics__grid--' | append: section.settings.columns
-%}

{%- style -%}
  .statistics-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top:      {{ section.settings.padding_top }}px;
    padding-bottom:   {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<div
  class="statistics statistics-{{ section.id }}"
  data-statistics
  data-animate="{{ section.settings.animate_numbers }}"
>
  <div class="page-width">

    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="statistics__header animate-on-scroll">
        {%- if section.settings.heading != blank -%}
          <h2 class="statistics__heading elixir-section-heading">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="statistics__subheading elixir-section-subheading">
            {{ section.settings.subheading }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <ul
      class="statistics__grid {{ col_class }} list-unstyled{% if section.settings.show_separator %} statistics__grid--sep{% endif %} animate-on-scroll"
    >
      {%- for block in stat_blocks -%}
        <li
          class="statistics__item"
          {{ block.shopify_attributes }}
        >
          <span
            class="statistics__value"
            data-count="{{ block.settings.value | escape }}"
            style="color: {{ block.settings.value_color }};"
          >
            {{- block.settings.value -}}
          </span>
          {%- if block.settings.description != blank -%}
            <p class="statistics__desc">{{ block.settings.description }}</p>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>

  </div>
</div>

{% schema %}
{
  "name": "Statistics",
  "tag": "section",
  "class": "section-statistics",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "4"
    },
    {
      "type": "checkbox",
      "id": "show_separator",
      "label": "Show separator between items",
      "info": "Vertical divider on desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "animate_numbers",
      "label": "Animate numbers on scroll",
      "default": true
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#0a0a0a"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Statistic",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "20,000+"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Happy customers"
        },
        {
          "type": "color",
          "id": "value_color",
          "label": "Value colour",
          "default": "#00e5ff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Statistics",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "value": "20,000+",
            "description": "Happy customers",
            "value_color": "#00e5ff"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "4.9",
            "description": "Average rating",
            "value_color": "#00e5ff"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "98%",
            "description": "Satisfaction rate",
            "value_color": "#00e5ff"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "#1",
            "description": "In its category",
            "value_color": "#00e5ff"
          }
        }
      ]
    }
  ]
}
{% endschema %}

{%- comment -%}
  sections/faq.liquid
  Accordion FAQ. Each block = one question/answer pair.
  Driven by assets/faq-accordion.js — no jQuery.
{%- endcomment -%}

{%- liquid
  assign faq_blocks = section.blocks | where: 'type', 'faq_item'
  assign icon_style = section.settings.icon_style
-%}

{%- style -%}
  .faq-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top:      {{ section.settings.padding_top }}px;
    padding-bottom:   {{ section.settings.padding_bottom }}px;
  }

  .faq-{{ section.id }} .faq__inner {
    max-width: {{ section.settings.max_width }}px;
    margin-inline: auto;
  }

  .faq-{{ section.id }} .faq__heading {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
  }

  .faq-{{ section.id }} .faq__question-text {
    font-size: {{ section.settings.question_size }}px;
    font-weight: {{ section.settings.question_weight }};
  }

  .faq-{{ section.id }} .faq__answer-inner {
    font-size: {{ section.settings.body_size }}px;
    font-weight: {{ section.settings.body_weight }};
  }
{%- endstyle -%}

<div
  class="faq faq-{{ section.id }}"
  data-faq
  data-icon="{{ icon_style }}"
  data-only-one="{{ section.settings.only_one_open }}"
  data-open-first="{{ section.settings.open_first }}"
>
  <div class="page-width">

    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="faq__header animate-on-scroll">
        {%- if section.settings.heading != blank -%}
          <h2 class="faq__heading elixir-section-heading">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="faq__subheading elixir-section-subheading">
            {{ section.settings.subheading }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="faq__inner animate-on-scroll">

      {%- for block in faq_blocks -%}
        <div
          class="faq__item{% if section.settings.open_first and forloop.first %} is-open{% endif %}"
          {{ block.shopify_attributes }}
        >
          <button
            class="faq__question"
            aria-expanded="{% if section.settings.open_first and forloop.first %}true{% else %}false{% endif %}"
            aria-controls="faq-answer-{{ section.id }}-{{ forloop.index0 }}"
          >
            <span class="faq__question-text">{{ block.settings.question }}</span>

            <span class="faq__icon" aria-hidden="true">
              {%- if icon_style == 'chevron' -%}
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              {%- else -%}
                {%- comment -%} Plus / minus {%- endcomment -%}
                <svg class="faq__icon-plus" viewBox="0 0 24 24" fill="none">
                  <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <svg class="faq__icon-minus" viewBox="0 0 24 24" fill="none">
                  <path d="M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
              {%- endif -%}
            </span>
          </button>

          <div
            class="faq__answer"
            id="faq-answer-{{ section.id }}-{{ forloop.index0 }}"
            aria-hidden="{% if section.settings.open_first and forloop.first %}false{% else %}true{% endif %}"
          >
            <div class="faq__answer-inner">
              {{ block.settings.answer }}
            </div>
          </div>
        </div>
      {%- endfor -%}

    </div>
  </div>
</div>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "class": "section-faq",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Accordion"
    },
    {
      "type": "select",
      "id": "icon_style",
      "label": "Icon style",
      "options": [
        { "value": "plus",    "label": "Plus / Minus" },
        { "value": "chevron", "label": "Chevron" }
      ],
      "default": "plus"
    },
    {
      "type": "checkbox",
      "id": "open_first",
      "label": "Open first item by default",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "only_one_open",
      "label": "Only one item open at a time",
      "default": false
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Content max width",
      "min": 600,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 800
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#0a0a0a"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Section heading size",
      "min": 24,
      "max": 56,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Section heading weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra-bold" }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "question_size",
      "label": "Question size",
      "min": 14,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "question_weight",
      "label": "Question weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" }
      ],
      "default": "500"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Answer text size",
      "min": 13,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "select",
      "id": "body_weight",
      "label": "Answer text weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" }
      ],
      "default": "400"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is your return policy?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>We offer a 30-day money back guarantee on all orders. If you're not satisfied for any reason, contact our support team and we'll process your refund promptly.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "How long does shipping take?",
            "answer": "<p>Standard shipping takes 3–5 business days. Expedited options are available at checkout. Once your order ships, you'll receive a tracking number via email.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "What is your return policy?",
            "answer": "<p>We offer a 30-day money back guarantee on all orders. If you're not completely satisfied, simply contact our support team and we'll arrange a full refund — no questions asked.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Are the ingredients safe and natural?",
            "answer": "<p>Yes. All ingredients are carefully sourced, rigorously tested for purity, and free from artificial fillers or additives. Our formulas are manufactured in GMP-certified facilities.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Do you offer a satisfaction guarantee?",
            "answer": "<p>Absolutely. We stand behind every product we sell with a 30-day satisfaction guarantee. If our product doesn't meet your expectations, we'll make it right.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}

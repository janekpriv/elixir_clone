{%- comment -%}
  sections/elixir-image-with-text.liquid
  Two-column layout: image + text column. Image can be left or right.
  Bullet and badge blocks render inside the text column.
{%- endcomment -%}

{%- liquid
  assign bullet_blocks = section.blocks | where: 'type', 'bullet'
  assign badge_blocks  = section.blocks | where: 'type', 'badge'

  case section.settings.image_ratio
    when '60-40'
      assign col_image = '60%'
      assign col_text  = '40%'
    when '40-60'
      assign col_image = '40%'
      assign col_text  = '60%'
    else
      assign col_image = '50%'
      assign col_text  = '50%'
  endcase

  assign image_left = true
  if section.settings.image_position == 'right'
    assign image_left = false
  endif
-%}

{%- style -%}
  .iwt-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top:      {{ section.settings.padding_top }}px;
    padding-bottom:   {{ section.settings.padding_bottom }}px;
  }

  @media screen and (min-width: 750px) {
    .iwt-{{ section.id }} .iwt__grid {
      grid-template-columns: {{ col_image }} {{ col_text }};
    }

    {%- if image_left == false -%}
      .iwt-{{ section.id }} .iwt__image-col {
        order: 2;
      }
      .iwt-{{ section.id }} .iwt__text-col {
        order: 1;
      }
    {%- endif -%}
  }

  .iwt-{{ section.id }} .iwt__image {
    border-radius: {{ section.settings.image_border_radius }}px;
  }

  .iwt-{{ section.id }} .iwt__heading {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
  }

  .iwt-{{ section.id }} .iwt__body {
    font-size: {{ section.settings.body_size }}px;
    font-weight: {{ section.settings.body_weight }};
  }
{%- endstyle -%}

<div class="iwt iwt-{{ section.id }}{% if section.settings.container_style == 'full' %} iwt--full{% endif %}">

  {%- if section.settings.container_style == 'contained' -%}
    <div class="page-width">
  {%- endif -%}

  <div class="iwt__grid">

    {%- comment -%}── Image column ──────────────────────────────────────{%- endcomment -%}
    <div class="iwt__image-col animate-on-scroll">
      {%- if section.settings.image != blank -%}
        {%- assign iwt_img_alt = section.settings.heading | escape -%}
        {{
          section.settings.image
          | image_url: width: 1200
          | image_tag:
            class: 'iwt__image',
            loading: 'lazy',
            widths: '400, 600, 800, 1000, 1200',
            sizes: '(max-width: 749px) 100vw, 50vw',
            alt: iwt_img_alt
        }}
      {%- else -%}
        <div class="iwt__image iwt__image--placeholder" aria-hidden="true">
          <svg viewBox="0 0 800 600" xmlns="http://www.w3.org/2000/svg">
            <rect width="800" height="600" fill="#1a1a1a"/>
            <text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle"
              fill="#444" font-size="24" font-family="sans-serif">Add an image</text>
          </svg>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%}── Text column ───────────────────────────────────────{%- endcomment -%}
    <div class="iwt__text-col animate-on-scroll" style="transition-delay: 150ms;">

      {%- if section.settings.eyebrow != blank -%}
        <p class="iwt__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="iwt__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <div class="iwt__body rte">{{ section.settings.body }}</div>
      {%- endif -%}

      {%- comment -%}── Bullet blocks ─────────────────────────────────{%- endcomment -%}
      {%- if bullet_blocks.size > 0 -%}
        <ul class="iwt__bullets list-unstyled">
          {%- for block in bullet_blocks -%}
            <li class="iwt__bullet" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != blank -%}
                {%- assign bullet_icon_alt = block.settings.text | escape -%}
                {{
                  block.settings.icon
                  | image_url: width: 40
                  | image_tag:
                    class: 'iwt__bullet-icon',
                    loading: 'lazy',
                    width: 20,
                    height: 20,
                    alt: bullet_icon_alt
                }}
              {%- else -%}
                <svg class="iwt__bullet-icon iwt__bullet-icon--default" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5"
                    stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              {%- endif -%}
              <span>{{ block.settings.text }}</span>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- comment -%}── Badge blocks ──────────────────────────────────{%- endcomment -%}
      {%- if badge_blocks.size > 0 -%}
        <div class="iwt__badges">
          {%- for block in badge_blocks -%}
            <div class="iwt__badge" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                {%- assign badge_img_alt = block.settings.text | escape -%}
                {{
                  block.settings.image
                  | image_url: width: 120
                  | image_tag:
                    class: 'iwt__badge-img',
                    loading: 'lazy',
                    width: 60,
                    alt: badge_img_alt
                }}
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <span class="iwt__badge-text">{{ block.settings.text }}</span>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%}── CTA button ────────────────────────────────────{%- endcomment -%}
      {%- if section.settings.cta_text != blank -%}
        <div class="iwt__cta">
          <a
            href="{{ section.settings.cta_url | default: '#' }}"
            class="btn-primary"
          >
            {{ section.settings.cta_text }}
          </a>
        </div>
      {%- endif -%}

    </div><!-- /.iwt__text-col -->
  </div><!-- /.iwt__grid -->

  {%- if section.settings.container_style == 'contained' -%}
    </div><!-- /.page-width -->
  {%- endif -%}

</div>

{% schema %}
{
  "name": "Image with text",
  "tag": "section",
  "class": "section-elixir-iwt",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left",  "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Column ratio",
      "options": [
        { "value": "50-50", "label": "50 / 50" },
        { "value": "60-40", "label": "60 / 40" },
        { "value": "40-60", "label": "40 / 60" }
      ],
      "default": "50-50"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 24,
      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "select",
      "id": "container_style",
      "label": "Container style",
      "options": [
        { "value": "contained", "label": "Contained" },
        { "value": "full",      "label": "Full-width" }
      ],
      "default": "contained"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Section Heading"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#0a0a0a"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 24,
      "max": 56,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra-bold" }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Body text size",
      "min": 13,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "body_weight",
      "label": "Body text weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" }
      ],
      "default": "400"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Bullet point",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon (optional)",
          "info": "Leave empty for default checkmark"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Key benefit or feature point"
        }
      ]
    },
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Badge text",
          "default": "As seen on Forbes"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Badge logo / image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image with text",
      "settings": {
        "image_position": "left",
        "heading": "Built for Results",
        "eyebrow": "Why it works"
      },
      "blocks": [
        {
          "type": "bullet",
          "settings": {
            "text": "Clinically studied ingredients at effective doses"
          }
        },
        {
          "type": "bullet",
          "settings": {
            "text": "Superior bioavailability with liposomal delivery"
          }
        },
        {
          "type": "bullet",
          "settings": {
            "text": "Manufactured in GMP-certified facilities"
          }
        }
      ]
    }
  ]
}
{% endschema %}

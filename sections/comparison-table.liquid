{%- comment -%}
  sections/comparison-table.liquid
  Three-column feature comparison table: Feature | Our Product | Other Brands.
  Cells can render ✓/✗ icons or plain text depending on block settings.
{%- endcomment -%}

{%- liquid
  assign row_blocks = section.blocks | where: 'type', 'row'
-%}

{%- style -%}
  .comparison-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top:      {{ section.settings.padding_top }}px;
    padding-bottom:   {{ section.settings.padding_bottom }}px;
  }

  .comparison-{{ section.id }} .comparison__our-cell {
    color: {{ section.settings.highlight_color }};
  }

  .comparison-{{ section.id }} .comparison__heading {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
  }

  .comparison-{{ section.id }} .comparison__td--feature {
    font-size: {{ section.settings.body_size }}px;
    font-weight: {{ section.settings.body_weight }};
  }
{%- endstyle -%}

<div class="comparison comparison-{{ section.id }}">
  <div class="page-width">

    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="comparison__header animate-on-scroll">
        {%- if section.settings.heading != blank -%}
          <h2 class="comparison__heading elixir-section-heading">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="comparison__subheading elixir-section-subheading">
            {{ section.settings.subheading }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="comparison__scroll-wrap animate-on-scroll">
      <table class="comparison__table" role="table">
        <thead>
          <tr>
            <th class="comparison__th comparison__th--feature" scope="col">Feature</th>
            <th class="comparison__th comparison__th--our" scope="col">
              {{ section.settings.our_column_name }}
            </th>
            <th class="comparison__th comparison__th--competitor" scope="col">
              {{ section.settings.competitor_column_name }}
            </th>
          </tr>
        </thead>

        <tbody>
          {%- for block in row_blocks -%}
            <tr class="comparison__row" {{ block.shopify_attributes }}>

              {%- comment -%}── Feature label ─────────────────────────────{%- endcomment -%}
              <td class="comparison__td comparison__td--feature">
                {{ block.settings.feature }}
              </td>

              {%- comment -%}── Our value ─────────────────────────────────{%- endcomment -%}
              <td class="comparison__td comparison__our-cell">
                {%- if block.settings.our_is_check -%}
                  {%- if block.settings.our_value == '✓' or block.settings.our_value == 'true' or block.settings.our_value == 'yes' -%}
                    <span class="comparison__check comparison__check--yes" aria-label="Yes">
                      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <circle cx="12" cy="12" r="10" fill="currentColor" opacity="0.15"/>
                        <path d="M8 12l3 3 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                  {%- else -%}
                    <span class="comparison__check comparison__check--no" aria-label="No">
                      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <circle cx="12" cy="12" r="10" fill="currentColor" opacity="0.1"/>
                        <path d="M15 9l-6 6M9 9l6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                      </svg>
                    </span>
                  {%- endif -%}
                {%- else -%}
                  {{ block.settings.our_value }}
                {%- endif -%}
              </td>

              {%- comment -%}── Competitor value ──────────────────────────{%- endcomment -%}
              <td class="comparison__td comparison__td--competitor">
                {%- if block.settings.competitor_is_check -%}
                  {%- if block.settings.competitor_value == '✓' or block.settings.competitor_value == 'true' or block.settings.competitor_value == 'yes' -%}
                    <span class="comparison__check comparison__check--yes" aria-label="Yes">
                      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <circle cx="12" cy="12" r="10" fill="currentColor" opacity="0.15"/>
                        <path d="M8 12l3 3 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                  {%- else -%}
                    <span class="comparison__check comparison__check--no" aria-label="No">
                      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <circle cx="12" cy="12" r="10" fill="currentColor" opacity="0.1"/>
                        <path d="M15 9l-6 6M9 9l6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                      </svg>
                    </span>
                  {%- endif -%}
                {%- else -%}
                  {{ block.settings.competitor_value }}
                {%- endif -%}
              </td>

            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    </div><!-- /.comparison__scroll-wrap -->

  </div>
</div>

{% schema %}
{
  "name": "Comparison table",
  "tag": "section",
  "class": "section-comparison",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Choose Us?"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Columns"
    },
    {
      "type": "text",
      "id": "our_column_name",
      "label": "Our product column name",
      "default": "Our Product"
    },
    {
      "type": "text",
      "id": "competitor_column_name",
      "label": "Competitor column name",
      "default": "Other Brands"
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Our product highlight colour",
      "default": "#00e5ff"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#0d0d0d"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Section heading size",
      "min": 24,
      "max": 56,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Section heading weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra-bold" }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Table text size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "body_weight",
      "label": "Table text weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" }
      ],
      "default": "400"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Feature row",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "Feature",
          "default": "Feature name"
        },
        {
          "type": "text",
          "id": "our_value",
          "label": "Our product value",
          "default": "✓"
        },
        {
          "type": "checkbox",
          "id": "our_is_check",
          "label": "Render as icon (✓ = green check, anything else = red cross)",
          "default": true
        },
        {
          "type": "text",
          "id": "competitor_value",
          "label": "Competitor value",
          "default": "✗"
        },
        {
          "type": "checkbox",
          "id": "competitor_is_check",
          "label": "Render competitor as icon",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Comparison table",
      "blocks": [
        {
          "type": "row",
          "settings": {
            "feature": "Premium Quality Materials",
            "our_value": "✓",
            "our_is_check": true,
            "competitor_value": "✗",
            "competitor_is_check": true
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "30-Day Money Back Guarantee",
            "our_value": "✓",
            "our_is_check": true,
            "competitor_value": "✗",
            "competitor_is_check": true
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "Free Shipping",
            "our_value": "✓",
            "our_is_check": true,
            "competitor_value": "✗",
            "competitor_is_check": true
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "24/7 Customer Support",
            "our_value": "✓",
            "our_is_check": true,
            "competitor_value": "✗",
            "competitor_is_check": true
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "Lifetime Warranty",
            "our_value": "✓",
            "our_is_check": true,
            "competitor_value": "✗",
            "competitor_is_check": true
          }
        }
      ]
    }
  ]
}
{% endschema %}

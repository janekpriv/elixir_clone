{%- comment -%}
  sections/hero.liquid
  Main hero section for homepage and landing pages — Elixir style.
  Supports 3 layout modes: image bg, video bg, split (text + image).
  All content is inline — no external snippet dependencies.
{%- endcomment -%}

{%- liquid
  assign layout        = section.settings.layout
  assign alignment     = section.settings.content_alignment
  assign overlay_alpha = section.settings.overlay_opacity | divided_by: 100.0
-%}

{%- style -%}
  /* ── Section wrapper ──────────────────────────────── */
  .hero-{{ section.id }} {
    position: relative;
    display: flex;
    align-items: center;
    min-height: {{ section.settings.min_height }}vh;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    overflow: hidden;
    background-color: var(--color-elixir-bg);
  }

  /* ── Full-bleed background (image & video modes) ─── */
  .hero-{{ section.id }} .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    {%- if layout == 'image' and section.settings.background_image != blank -%}
    background-image: url('{{ section.settings.background_image | image_url: width: 2000 }}');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    {%- endif -%}
  }

  .hero-{{ section.id }} .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* ── Overlay ─────────────────────────────────────── */
  .hero-{{ section.id }} .hero__overlay {
    position: absolute;
    inset: 0;
    background-color: {{ section.settings.overlay_color }};
    opacity: {{ overlay_alpha }};
    z-index: 1;
  }

  /* ── Inner / content layer ───────────────────────── */
  .hero-{{ section.id }} .hero__inner {
    position: relative;
    z-index: 2;
    width: 100%;
  }

  /* ── Content alignment ───────────────────────────── */
  .hero-{{ section.id }} .hero__content {
    max-width: 680px;
    {%- if alignment == 'center' -%}
    margin-inline: auto;
    text-align: center;
    {%- endif -%}
  }

  /* ── Split layout ────────────────────────────────── */
  .hero-{{ section.id }} .hero__split {
    display: grid;
    grid-template-columns: 60fr 40fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-{{ section.id }} .hero__split-img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-xl);
    object-fit: cover;
  }

  /* ── Trust icons row ─────────────────────────────── */
  .hero-{{ section.id }} .hero__trust-icons {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
    margin-bottom: 2rem;
    {%- if alignment == 'center' -%}
    justify-content: center;
    {%- endif -%}
  }

  .hero-{{ section.id }} .hero__trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .hero-{{ section.id }} .hero__trust-item img {
    width: 20px;
    height: 20px;
    object-fit: contain;
    flex-shrink: 0;
  }

  /* ── CTA row ─────────────────────────────────────── */
  .hero-{{ section.id }} .hero__cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1rem;
    {%- if alignment == 'center' -%}
    justify-content: center;
    {%- endif -%}
  }

  /* ── Mobile ──────────────────────────────────────── */
  @media (max-width: 749px) {
    .hero-{{ section.id }} {
      min-height: 70vh;
    }

    .hero-{{ section.id }} .hero__split {
      grid-template-columns: 1fr;
    }

    .hero-{{ section.id }} .hero__split-image {
      order: -1;
    }

    .hero-{{ section.id }} .hero__content {
      max-width: 100%;
    }

    .hero-{{ section.id }} .hero__cta-row .btn-primary,
    .hero-{{ section.id }} .hero__cta-row .btn-secondary {
      width: 100%;
      justify-content: center;
    }
  }
{%- endstyle -%}

<section
  class="hero hero--{{ layout }} hero-{{ section.id }}"
  aria-label="{{ section.settings.heading | default: 'Hero' | escape }}"
>

  {%- comment -%}────────────────── Background layer ─────────────────────{%- endcomment -%}
  {%- unless layout == 'split' -%}
    <div class="hero__bg">
      {%- if layout == 'video' and section.settings.video_url != blank -%}
        <video
          class="hero__video"
          autoplay
          muted
          loop
          playsinline
          preload="none"
          {%- if section.settings.video_poster != blank -%}
            poster="{{ section.settings.video_poster | image_url: width: 1920 }}"
          {%- endif -%}
        >
          <source src="{{ section.settings.video_url }}" type="video/mp4">
        </video>
      {%- endif -%}
      <div class="hero__overlay" aria-hidden="true"></div>
    </div>
  {%- endunless -%}

  {%- comment -%}────────────────── Content layer ────────────────────────{%- endcomment -%}
  <div class="hero__inner page-width">

    {%- if layout == 'split' -%}

      <div class="hero__split">
        <div class="hero__split-text animate-on-scroll">

          {%- comment -%} ── Eyebrow ─────────────────────────────────── {%- endcomment -%}
          {%- if section.settings.eyebrow_text != blank -%}
            <span class="hero__eyebrow elixir-section-eyebrow">
              {{- section.settings.eyebrow_text -}}
            </span>
          {%- endif -%}

          {%- comment -%} ── Heading ─────────────────────────────────── {%- endcomment -%}
          {%- if section.settings.heading != blank -%}
            <h1 class="hero__heading">{{ section.settings.heading }}</h1>
          {%- endif -%}

          {%- comment -%} ── Subheading ──────────────────────────────── {%- endcomment -%}
          {%- if section.settings.subheading != blank -%}
            <p class="hero__subheading">{{ section.settings.subheading }}</p>
          {%- endif -%}

          {%- comment -%} ── Trust icons ─────────────────────────────── {%- endcomment -%}
          {%- if section.blocks.size > 0 -%}
            <ul class="hero__trust-icons list-unstyled">
              {%- for block in section.blocks -%}
                {%- if block.type == 'trust_icon' -%}
                  <li class="hero__trust-item" {{ block.shopify_attributes }}>
                    {%- if block.settings.icon != blank -%}
                      {%- assign trust_icon_alt = block.settings.text | escape -%}
                      {{
                        block.settings.icon
                        | image_url: width: 40
                        | image_tag:
                          loading: 'lazy',
                          alt: trust_icon_alt,
                          width: 20,
                          height: 20
                      }}
                    {%- else -%}
                      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                        <path d="M10 1l2.39 4.84 5.35.78-3.87 3.77.91 5.33L10 13.27l-4.78 2.45.91-5.33L2.26 6.62l5.35-.78L10 1z" fill="var(--color-accent)"/>
                      </svg>
                    {%- endif -%}
                    {%- if block.settings.text != blank -%}
                      <span class="hero__trust-label">{{ block.settings.text }}</span>
                    {%- endif -%}
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          {%- endif -%}

          {%- comment -%} ── CTA buttons ─────────────────────────────── {%- endcomment -%}
          {%- if section.settings.cta_primary_text != blank -%}
            <div class="hero__cta-row">
              <a
                href="{{ section.settings.cta_primary_url | default: routes.root_url }}"
                class="btn-primary"
              >
                {{- section.settings.cta_primary_text -}}
              </a>
              {%- if section.settings.cta_secondary_text != blank -%}
                <a
                  href="{{ section.settings.cta_secondary_url | default: routes.root_url }}"
                  class="btn-secondary"
                >
                  {{- section.settings.cta_secondary_text -}}
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}

          {%- comment -%} ── Trust badge ─────────────────────────────── {%- endcomment -%}
          {%- if section.settings.trust_badge_text != blank -%}
            <p class="hero__trust-badge">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M7 1l1.47 2.98 3.29.48-2.38 2.32.56 3.28L7 8.41l-2.94 1.65.56-3.28L2.24 4.46l3.29-.48L7 1z" fill="var(--color-accent)"/>
              </svg>
              {{ section.settings.trust_badge_text }}
            </p>
          {%- endif -%}

        </div><!-- /.hero__split-text -->

        <div class="hero__split-image">
          {%- if section.settings.background_image != blank -%}
            {{
              section.settings.background_image
              | image_url: width: 900
              | image_tag:
                loading: 'eager',
                class: 'hero__split-img',
                widths: '400, 600, 900',
                sizes: '(max-width: 749px) 100vw, 40vw',
                alt: section.settings.background_image.alt | default: section.settings.heading | escape
            }}
          {%- endif -%}
        </div>

      </div><!-- /.hero__split -->

    {%- else -%}

      {%- comment -%}──── Image / Video mode: centred or left-aligned content ────{%- endcomment -%}
      <div class="hero__content animate-on-scroll">

        {%- comment -%} ── Eyebrow ─────────────────────────────────── {%- endcomment -%}
        {%- if section.settings.eyebrow_text != blank -%}
          <span class="hero__eyebrow elixir-section-eyebrow">
            {{- section.settings.eyebrow_text -}}
          </span>
        {%- endif -%}

        {%- comment -%} ── Heading ─────────────────────────────────── {%- endcomment -%}
        {%- if section.settings.heading != blank -%}
          <h1 class="hero__heading">{{ section.settings.heading }}</h1>
        {%- endif -%}

        {%- comment -%} ── Subheading ──────────────────────────────── {%- endcomment -%}
        {%- if section.settings.subheading != blank -%}
          <p class="hero__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}

        {%- comment -%} ── Trust icons ─────────────────────────────── {%- endcomment -%}
        {%- if section.blocks.size > 0 -%}
          <ul class="hero__trust-icons list-unstyled">
            {%- for block in section.blocks -%}
              {%- if block.type == 'trust_icon' -%}
                <li class="hero__trust-item" {{ block.shopify_attributes }}>
                  {%- if block.settings.icon != blank -%}
                    {%- assign trust_icon_alt = block.settings.text | escape -%}
                    {{
                      block.settings.icon
                      | image_url: width: 40
                      | image_tag:
                        loading: 'lazy',
                        alt: trust_icon_alt,
                        width: 20,
                        height: 20
                    }}
                  {%- else -%}
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                      <path d="M10 1l2.39 4.84 5.35.78-3.87 3.77.91 5.33L10 13.27l-4.78 2.45.91-5.33L2.26 6.62l5.35-.78L10 1z" fill="var(--color-accent)"/>
                    </svg>
                  {%- endif -%}
                  {%- if block.settings.text != blank -%}
                    <span class="hero__trust-label">{{ block.settings.text }}</span>
                  {%- endif -%}
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- comment -%} ── CTA buttons ─────────────────────────────── {%- endcomment -%}
        {%- if section.settings.cta_primary_text != blank -%}
          <div class="hero__cta-row">
            <a
              href="{{ section.settings.cta_primary_url | default: routes.root_url }}"
              class="btn-primary"
            >
              {{- section.settings.cta_primary_text -}}
            </a>
            {%- if section.settings.cta_secondary_text != blank -%}
              <a
                href="{{ section.settings.cta_secondary_url | default: routes.root_url }}"
                class="btn-secondary"
              >
                {{- section.settings.cta_secondary_text -}}
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- comment -%} ── Trust badge ─────────────────────────────── {%- endcomment -%}
        {%- if section.settings.trust_badge_text != blank -%}
          <p class="hero__trust-badge">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M7 1l1.47 2.98 3.29.48-2.38 2.32.56 3.28L7 8.41l-2.94 1.65.56-3.28L2.24 4.46l3.29-.48L7 1z" fill="var(--color-accent)"/>
            </svg>
            {{ section.settings.trust_badge_text }}
          </p>
        {%- endif -%}

      </div><!-- /.hero__content -->

    {%- endif -%}

  </div><!-- /.hero__inner -->
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "image", "label": "Image background" },
        { "value": "video", "label": "Video background" },
        { "value": "split", "label": "Split (text + image)" }
      ],
      "default": "image"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 90
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "info": "Used as background (image/video mode) or right-column image (split mode)"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (mp4)",
      "info": "Direct link to an .mp4 file. Used in Video layout only."
    },
    {
      "type": "image_picker",
      "id": "video_poster",
      "label": "Video poster image",
      "info": "Shown while video loads. Required for video layout."
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay colour",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 45
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow text",
      "default": "TRUSTED BY 20K+ CUSTOMERS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Premium Formula That Changes Everything"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Experience the difference with our science-backed formula. Real results, guaranteed."
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "cta_primary_text",
      "label": "Primary button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary button URL"
    },
    {
      "type": "text",
      "id": "cta_secondary_text",
      "label": "Secondary button text"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary button URL"
    },
    {
      "type": "text",
      "id": "trust_badge_text",
      "label": "Trust badge text",
      "default": "30-Day Money-Back Guarantee",
      "info": "Small text displayed below the buttons"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "trust_icon",
      "name": "Trust icon",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image",
          "info": "Small icon (20×20px). Leave empty to use a default star icon."
        },
        {
          "type": "text",
          "id": "text",
          "label": "Label text",
          "default": "Free Shipping"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "settings": {
        "layout": "image",
        "content_alignment": "left",
        "min_height": 90,
        "overlay_opacity": 45,
        "eyebrow_text": "TRUSTED BY 20K+ CUSTOMERS",
        "heading": "The Premium Formula That Changes Everything",
        "subheading": "Experience the difference with our science-backed formula. Real results, guaranteed.",
        "cta_primary_text": "Shop Now",
        "cta_secondary_text": "Learn More",
        "trust_badge_text": "30-Day Money-Back Guarantee"
      },
      "blocks": [
        { "type": "trust_icon", "settings": { "text": "Free Shipping" } },
        { "type": "trust_icon", "settings": { "text": "30-Day Guarantee" } },
        { "type": "trust_icon", "settings": { "text": "Secure Checkout" } }
      ]
    }
  ]
}
{% endschema %}
